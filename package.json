{
	"name": "biolab",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"packageManager": "bun@1.3.13",
	"engines": {
		"node": ">=22",
		"npm": "!",
		"pnpm": "!",
		"yarn": "!"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"preview": "turbo preview",
		"check": "turbo check",
		"check:watch": "turbo check:watch",
		"format": "prettier --write .",
		"lint": "turbo lint",
		"lint:style": "turbo lint:style",
		"test": "turbo test",
		"test:unit": "turbo test:unit",
		"clean": "turbo clean",
		"tauri": "bun --filter @biolab/desktop tauri"
	},
	"devDependencies": {
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "4.1.1",
		"svelte": "5.56.4",
		"turbo": "2.10.0"
	},
	"trustedDependencies": [
		"esbuild"
	],
	"overrides": {
		"esrap": "2.2.11",
		"prettier": "3.9.4",
		"prettier-plugin-svelte": "4.1.1",
		"svelte": "5.56.4"
	}
}
