{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "BioLab",
	"version": "0.1.0",
	"identifier": "com.biomaru.biolab",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "BioLab",
				"width": 1000,
				"height": 700,
				"minWidth": 720,
				"minHeight": 480,
				"transparent": true,
				"titleBarStyle": "Overlay",
				"hiddenTitle": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"endpoints": [
				"https://github.com/BioMaRu/biolab/releases/latest/download/latest.json"
			],
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY3RTJEMkIxNDc5NzMxMjMKUldRak1aZEhzZExpWjdzZlZ0WWJkaFNQSnNDTWgvdnJVV1N4UjIzNnhSN3ZML0pBOWwvUXlqN08K"
		}
	}
}
